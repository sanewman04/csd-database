<%= form_with(model: patient) do |form| %>
  <% if patient.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(patient.errors.count, "error") %> prohibited this patient from being saved:</h2>

      <ul>
        <% patient.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :age, style: "display: block" %>
    <%= form.number_field :age %>
  </div>

  <div>
    <%= form.label :gender, style: "display: block" %>
    <%= form.textarea :gender %>
  </div>

  <div>
    <%= form.label :education_level, style: "display: block" %>
    <%= form.textarea :education_level %>
  </div>

  <div>
    <%= form.label :medical_history, style: "display: block" %>
    <%= form.textarea :medical_history %>
  </div>

  <div>
    <%= form.label :diet, style: "display: block" %>
    <%= form.textarea :diet %>
  </div>

  <div>
    <%= form.label :current_treatment, style: "display: block" %>
    <%= form.textarea :current_treatment %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
